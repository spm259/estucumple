# --- Database ---
# Defaults to a local SQLite file if unset.
DATABASE_URL=sqlite:///./es_tu_cumple.db

# --- Kapso (WhatsApp provider) ---
# From the Kapso dashboard: Project Settings > API Keys, and your WhatsApp number.
KAPSO_API_BASE=https://api.kapso.ai/meta/whatsapp/v24.0
KAPSO_API_KEY=your-kapso-project-api-key
KAPSO_PHONE_NUMBER_ID=your-phone-number-id
# Shared secret you set when registering the webhook; used to verify signatures.
KAPSO_WEBHOOK_SECRET=your-webhook-secret

# --- Reminders ---
# Name + language of the APPROVED WhatsApp template used for the daily reminder.
REMINDER_TEMPLATE_NAME=birthday_reminder
REMINDER_TEMPLATE_LANG=es
# Local hour (0-23) at which reminders are sent.
REMINDER_HOUR=9
APP_TIMEZONE=America/Argentina/Buenos_Aires
